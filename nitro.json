{
  "android": {
    "androidCxxLibName": "UnifiedPlayer",
    "androidNamespace": [
      "unifiedplayer"
    ]
  },
  "cxxNamespace": [
    "unifiedplayer"
  ],
  "ios": {
    "iosModuleName": "UnifiedPlayer"
  },
  "ignorePaths": ["drm-plugin", "node_modules"],
  "autolinking": {
    "VideoPlayerFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridVideoPlayerFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridVideoPlayerFactory"
      }
    },
    "VideoPlayerSourceFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridVideoPlayerSourceFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridVideoPlayerSourceFactory"
      }
    },
    "VideoViewViewManagerFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridVideoViewViewManagerFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridVideoViewViewManagerFactory"
      }
    }
  }
}
